# Local dev — points Vite to the local API server on :5001.
# Copy to .env.development and edit if your API is on a different host/port.
VITE_API_BASE=http://localhost:5001

# Production — replace with your real API domain (e.g. https://api.mianliao.cn).
# Copy to .env.production before `npm run build`.
# VITE_API_BASE=https://api.example.com