# ===== 钉钉开放平台凭证 =====
# 在 https://open-dev.dingtalk.com 开发者后台获取
# corpId 在「我的组织」或「管理后台 > 企业信息」

DINGTALK_CORP_ID=
DINGTALK_APP_KEY=
DINGTALK_APP_SECRET=
DINGTALK_AGENT_ID=

# ===== 运行选项 =====
# 设为 true 打印所有 API 调用但不实际执行
DRY_RUN=false
# 设为 true 打印详细 HTTP 日志
VERBOSE=false
# 每次请求超时（秒）
HTTP_TIMEOUT=30
# 请求失败重试次数
HTTP_RETRIES=3
# 批量导入每批条数（钉钉接口有上限）
BATCH_SIZE=100

# ===== 数据源 =====
# 数据文件路径（相对于此 openapi/ 目录）
DATA_FILE=../面料推荐_预转数据_86条.xlsx

# ===== AI 表格配置 =====
TABLE_NAME=面料推荐总表
TABLE_DESCRIPTION=工厂/打样师参考用，含 5 家供应商 86+ 款面料，支持智能搜索、卖点生成、识图录入
