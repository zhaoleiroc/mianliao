# --- Server ---
NODE_ENV=development
PORT=5001
HOST=0.0.0.0

# --- Database (MSSQL) ---
DB_SERVER=localhost
DB_PORT=1433
DB_NAME=mianliao
DB_USER=sa
DB_PASSWORD=505375
DB_ENCRYPT=false
DB_TRUST_CERT=true

# --- Auth ---
JWT_SECRET=change-me-in-production-this-must-be-at-least-32-chars
JWT_ISSUER=mianliao
JWT_AUDIENCE=mianliao-web
JWT_ACCESS_TTL=3600          # seconds (1 hour)
JWT_REFRESH_TTL=604800       # seconds (7 days)

# --- CORS (comma-separated origins) ---
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# --- Uploads ---
UPLOAD_MAX_SIZE=5242880      # 5 MB
UPLOAD_DIR=wwwroot/uploads

# --- Seed ---
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=Admin@123
SEED_ADMIN_DISPLAY_NAME=系统管理员
